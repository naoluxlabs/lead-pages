---
const data = {
  title: "The Beginner Peptide Stack — Over 40",
  badge: "Free Cheatsheet",
  headline: "5 Peptides Every Beginner Over 40 Should Know First",
  subtitle: "The complete starter guide to recovery, body composition, and longevity peptides — all legally accessible in 2026.",
  pdfUrl: "https://drive.google.com/uc?export=download&id=1D-QG9ljAJ4Ie6W7Qb_ZOFAf4BAYHbh6i",
  valueProps: [
    "BPC-157 and TB-500: the recovery stack explained",
    "CJC-1295 + Ipamorelin: the growth hormone duo",
    "GHK-Cu for collagen and anti-aging at the cellular level",
    "Thymosin Alpha-1 for immune regulation — reclassified legal in 2026",
  ],
  ctaText: "Get the Free Cheatsheet",
  source: "beginner-peptide-stack-over-40",
};
---
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" /><meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{data.title} — Naolux Labs</title>
  <style>* { margin: 0; padding: 0; box-sizing: border-box; } body { font-family: 'Segoe UI', sans-serif; background: #0a0a0a; color: #fff; min-height: 100vh; display: flex; align-items: center; justify-content: center; } .container { max-width: 580px; padding: 48px 32px; text-align: center; } .badge { display: inline-block; background: #c9a84c; color: #000; font-size: 11px; font-weight: 700; letter-spacing: 2px; padding: 6px 16px; border-radius: 20px; margin-bottom: 24px; text-transform: uppercase; } h1 { font-size: 2.2rem; font-weight: 800; line-height: 1.2; margin-bottom: 16px; } .subtitle { font-size: 1.05rem; color: #aaa; line-height: 1.7; margin-bottom: 24px; } .value-props { list-style: none; text-align: left; margin-bottom: 32px; display: flex; flex-direction: column; gap: 10px; } .value-props li { display: flex; align-items: flex-start; gap: 10px; color: #ccc; font-size: 0.95rem; } .value-props li::before { content: "✓"; color: #c9a84c; font-weight: 700; flex-shrink: 0; } form { display: flex; flex-direction: column; gap: 12px; } input { padding: 16px 20px; border-radius: 8px; border: 1px solid #333; background: #111; color: #fff; font-size: 1rem; outline: none; } input:focus { border-color: #c9a84c; } button { padding: 16px; background: #c9a84c; color: #000; font-size: 1rem; font-weight: 700; border: none; border-radius: 8px; cursor: pointer; } .note { font-size: 0.8rem; color: #555; margin-top: 12px; } .success { display: none; padding: 20px; background: #111; border: 1px solid #c9a84c; border-radius: 8px; margin-top: 16px; color: #c9a84c; font-weight: 600; }</style>
</head>
<body>
  <div class="container">
    <div class="badge">{data.badge}</div>
    <h1>{data.headline}</h1>
    <p class="subtitle">{data.subtitle}</p>
    <ul class="value-props">{data.valueProps.map(prop => <li>{prop}</li>)}</ul>
    <form id="form">
      <input type="text" id="name" placeholder="Your first name" required />
      <input type="email" id="email" placeholder="Your email address" required />
      <button type="submit">{data.ctaText} →</button>
    </form>
    <p class="note">No spam. Unsubscribe anytime.</p>
    <div class="success" id="success">✓ Your cheatsheet is downloading now!</div>
  </div>
  <script define:vars={{ pdfUrl: data.pdfUrl, source: data.source }}>
    document.getElementById('form').addEventListener('submit', async (e) => {
      e.preventDefault();
      const name = document.getElementById('name').value;
      const email = document.getElementById('email').value;
      try { await fetch('https://naolux-landing.vercel.app/api/capture', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ name, email, source }) }); } catch {}
      document.getElementById('form').style.display = 'none';
      document.getElementById('success').style.display = 'block';
      const a = document.createElement('a'); a.href = pdfUrl; a.download = ''; document.body.appendChild(a); a.click(); document.body.removeChild(a);
    });
  </script>
</body>
</html>
